// ─── RECHERCHE ───
const input = document.getElementById('search-input');
const suggestionsEl = document.getElementById('suggestions');
let searchResults = [], resultsToShow = 5, activeIndex = -1;

input.addEventListener('input', async () => {
    const raw = input.value.trim();
    if (raw.length < 2) { suggestionsEl.innerHTML = ''; searchResults = []; return; }
    const q = removeAccents(raw);

    const [movieData, tvData, collData] = await Promise.all([
        tmdb(`/search/movie?query=${encodeURIComponent(q)}&page=1`),
        tmdb(`/search/tv?query=${encodeURIComponent(q)}&page=1`),
        tmdb(`/search/collection?query=${encodeURIComponent(q)}&page=1`)
    ]);

    const movies = (movieData.results || []).map(m => ({...m, type:'movie'}));
    const series = (tvData.results || []).map(s => ({...s, type:'tv'}));
    const colls = (collData.results || []).filter(c => c.poster_path).map(c => ({...c, type:'collection'}));

    const fuse = new Fuse([...movies, ...series, ...colls], {
        keys: ['title','name'],
        threshold: 0.4,
        ignoreLocation: true,
        getFn: (obj, path) => {
            const v = Fuse.config.getFn(obj, path);
            return v ? removeAccents(v.toString()) : '';
        }
    });

    searchResults = fuse.search(q).map(r => r.item)
        .sort((a, b) => (b.popularity || 0) - (a.popularity || 0));
    activeIndex = 0;
    resultsToShow = 5;
    renderSuggestions();
});

function renderSuggestions() {
    suggestionsEl.innerHTML = '';
    searchResults.slice(0, resultsToShow).forEach((item, i) => {
        const title = item.title || item.name;
        const year = (item.release_date || item.first_air_date || '').slice(0, 4);
        const img = item.poster_path ? `${BASE_IMG}w92${item.poster_path}` : '';
        const typeLabel = item.type === 'movie' ? 'Film' : item.type === 'tv' ? 'Série' : 'Collection';

        const div = document.createElement('div');
        div.className = 'suggestion' + (i === activeIndex ? ' active' : '');
        div.innerHTML = `
            <img src="${img}" alt="">
            <div class="suggestion-details">
                <div class="suggestion-title">${title}</div>
                <div class="suggestion-year">${year || 'Année inconnue'} | ${typeLabel}</div>
            </div>`;
        div.addEventListener('click', () => { suggestionsEl.innerHTML = ''; input.value = ''; openPopup(item); });
        suggestionsEl.appendChild(div);
    });

    if (searchResults.length > resultsToShow) {
        const btn = document.createElement('button');
        btn.id = 'load-more-btn';
        btn.textContent = 'Afficher plus';
        btn.addEventListener('click', e => { e.stopPropagation(); resultsToShow += 5; renderSuggestions(); });
        suggestionsEl.appendChild(btn);
    }
}

input.addEventListener('keydown', e => {
    const items = suggestionsEl.querySelectorAll('.suggestion');
    if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = (activeIndex+1) % Math.min(searchResults.length, resultsToShow); refreshActive(items); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = (activeIndex-1+Math.min(searchResults.length, resultsToShow)) % Math.min(searchResults.length, resultsToShow); refreshActive(items); }
    else if (e.key === 'Enter' && activeIndex > -1) { e.preventDefault(); openPopup(searchResults[activeIndex]); suggestionsEl.innerHTML = ''; }
});

function refreshActive(items) {
    items.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
}

