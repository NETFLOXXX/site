<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="https://i.ibb.co/VYfvTC6F/untilted-1752571740-trimmy.png" type="image/png">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@500;600&display=swap" rel="stylesheet">
    <title>NETFLOX</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Arial', sans-serif;
            background-color: #141414;
            color: white;
            overflow-x: hidden;
        }

        /* ─── HEADER ─── */
        .header {
            position: fixed;
            top: 0;
            width: 100%;
            background: linear-gradient(180deg, rgba(0,0,0,0.7) 10%, transparent);
            z-index: 1000;
            padding: 20px 60px;
            transition: background-color 0.3s ease;
        }
        .header.scrolled { background-color: #141414; }

        .nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 25px;
            flex: 1;
        }

        .logo {
            font-size: 48px;
            font-weight: normal;
            color: #e50914;
            text-decoration: none;
            font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
            letter-spacing: 1px;
            flex-shrink: 0;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 20px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            transition: color 0.3s;
            font-family: 'Montserrat', sans-serif;
            font-weight: 500;
            font-size: 16px;
            white-space: nowrap;
        }
        .nav-links a:hover { color: #e50914; }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-shrink: 0;
        }

        /* ─── SEARCH ─── */
        .search-container {
            position: relative;
            display: flex;
            align-items: center;
            background: rgba(0,0,0,0.5);
            border-radius: 50px;
            padding: 5px 15px;
        }
        .search-icon { margin-right: 10px; flex-shrink: 0; }

        #search-input {
            width: 320px;
            padding: 10px 15px;
            font-size: 15px;
            border: none;
            border-radius: 50px;
            background: transparent;
            color: white;
            outline: none;
        }

        .suggestions {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background: rgba(0,0,0,0.95);
            border-radius: 20px;
            margin-top: 5px;
            overflow: hidden;
            max-height: 400px;
            overflow-y: auto;
            z-index: 999;
        }

        .suggestion {
            display: flex;
            align-items: center;
            padding: 10px;
            cursor: pointer;
            transition: background 0.2s;
        }
        .suggestion:hover, .suggestion.active { background: rgba(255,255,255,0.1); }
        .suggestion img { width: 50px; height: 75px; object-fit: cover; border-radius: 10px; margin-right: 15px; }
        .suggestion-title { font-size: 16px; font-weight: bold; }
        .suggestion-year { font-size: 14px; color: #aaa; }

        #load-more-btn {
            width: 100%;
            padding: 10px 0;
            background: rgba(0,0,0,0.5);
            border: none;
            border-top: 1px solid rgba(255,255,255,0.1);
            color: white;
            font-size: 15px;
            cursor: pointer;
            border-radius: 0 0 20px 20px;
            transition: background 0.2s;
        }
        #load-more-btn:hover { background: rgba(255,255,255,0.1); }

        /* ─── LOGIN BTN ─── */
        .login-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #e50914;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 10px 20px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Montserrat', sans-serif;
            white-space: nowrap;
        }
        .login-btn svg { width: 20px; height: 20px; fill: white; }
        .login-btn:hover { background: #c40812; transform: scale(1.05); }

        .user-icon-mobile {
            display: none;
            width: 36px; height: 36px;
            cursor: pointer;
            background: #e50914;
            border-radius: 50%;
            padding: 8px;
        }
        .user-icon-mobile svg { width: 100%; height: 100%; fill: white; }

        /* ─── BURGER ─── */
        .burger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            width: 25px; height: 20px;
            position: relative;
        }
        .burger div { width: 100%; height: 3px; background: white; transition: all 0.3s; border-radius: 2px; }
        .burger.active div:nth-child(1) { transform: rotate(45deg); position: absolute; top: 50%; margin-top: -1.5px; }
        .burger.active div:nth-child(2) { opacity: 0; }
        .burger.active div:nth-child(3) { transform: rotate(-45deg); position: absolute; top: 50%; margin-top: -1.5px; }

        /* ─── HERO ─── */
        .hero {
            position: relative;
            height: 100vh;
            background-size: cover;
            background-position: center;
            transition: background-image 0.8s ease-in-out;
        }
        .hero-overlay {
            background: linear-gradient(to top, #141414 0%, rgba(20,20,20,0.6) 50%, transparent 100%);
            height: 100%;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 60px;
            position: relative;
        }
        .hero-content {
            max-width: 50%;
            z-index: 2;
            animation: fadeInText 1s ease-in-out forwards;
            opacity: 0;
        }
        .hero-title { font-size: 48px; margin-bottom: 20px; font-weight: bold; }
        .hero-description { font-size: 17px; margin-bottom: 30px; line-height: 1.6; color: #ddd; }
        .hero-buttons { display: flex; gap: 15px; flex-wrap: wrap; }

        .hero-poster {
            width: 250px;
            height: auto;
            border-radius: 12px;
            cursor: pointer;
            transition: transform 0.4s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            z-index: 2;
        }
        .hero-poster:hover { transform: scale(1.08); }

        .hero-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(20,20,20,0.7);
            color: white;
            font-size: 24px;
            border: none;
            border-radius: 50%;
            width: 50px; height: 50px;
            cursor: pointer;
            z-index: 10;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: background 0.3s;
        }
        .hero-nav:hover { background: rgba(229,9,20,0.9); }
        .hero-prev { left: 20px; }
        .hero-next { right: 20px; }

        @keyframes fadeInText {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .hero-content.fade-out { animation: fadeOutText 0.5s ease-in-out forwards; }
        @keyframes fadeOutText {
            0% { opacity: 1; transform: translateY(0); }
            100% { opacity: 0; transform: translateY(-20px); }
        }
        .hero-content.fade-in { animation: fadeInText 0.8s ease-out forwards; }

        /* ─── BUTTONS ─── */
        .btn {
            padding: 13px 28px;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
        }
        .btn-primary { background: #e50914; color: white; }
        .btn-primary:hover { background: #c40812; }
        .btn-secondary { background: rgba(109,109,110,0.7); color: white; }
        .btn-secondary:hover { background: rgba(109,109,110,0.9); }

        /* ─── CONTENT ─── */
        .content { padding: 40px 60px 80px; }

        .section { margin-bottom: 50px; }
        .section-title { font-size: 24px; margin-bottom: 20px; font-weight: bold; }

        .row {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            padding: 10px 0;
            scrollbar-width: thin;
            scrollbar-color: #e50914 #333;
        }
        .row::-webkit-scrollbar { height: 6px; }
        .row::-webkit-scrollbar-track { background: #333; border-radius: 10px; }
        .row::-webkit-scrollbar-thumb { background: #e50914; border-radius: 10px; }

        /* ─── MOVIE CARDS ─── */
        .movie-card {
            min-width: 185px;
            height: 278px;
            background: #333;
            border-radius: 10px;
            cursor: pointer;
            transition: transform 0.3s;
            position: relative;
            overflow: hidden;
            background-size: cover;
            background-position: center;
            flex-shrink: 0;
        }
        .movie-card:hover { transform: scale(1.07); z-index: 5; }

        .card-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(transparent 50%, rgba(0,0,0,0.85));
            opacity: 0;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 14px;
            transition: opacity 0.3s;
        }
        .movie-card:hover .card-overlay { opacity: 1; }
        .card-title { font-weight: bold; font-size: 15px; }
        .card-meta { font-size: 12px; color: #ccc; margin-top: 3px; }

        /* ─── RANDOM BTN ─── */
        #randomBtn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: linear-gradient(135deg, #e50914, #ff1744);
            color: white;
            border: none;
            border-radius: 999px;
            padding: 16px 32px;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 6px 16px rgba(0,0,0,0.35);
            z-index: 999;
            transition: all 0.3s;
        }
        #randomBtn:hover { background: linear-gradient(135deg, #c40812, #e50914); transform: scale(1.05); }

        /* ─── OVERLAYS / POPUPS ─── */
        .tv-overlay, .episode-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .tv-popup {
            background: #141414;
            padding: 30px;
            border-radius: 16px;
            max-width: 90vw;
            width: 900px;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            border: 2px solid #e50914;
            animation: popupIn 0.3s ease-out forwards;
        }

        .episode-popup {
            background: #141414;
            padding: 25px;
            border-radius: 16px;
            max-width: 90vw;
            width: 900px;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            border: 2px solid #e50914;
            animation: popupIn 0.3s ease-out forwards;
        }

        @keyframes popupIn {
            from { transform: scale(0.85); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .close-btn {
            position: absolute;
            top: 12px; right: 20px;
            color: white;
            font-size: 28px;
            cursor: pointer;
            z-index: 10;
            line-height: 1;
        }

        .tv-content { display: flex; gap: 24px; flex-wrap: wrap; }
        .popup-left img { width: 250px; border-radius: 10px; box-shadow: 0 5px 20px rgba(0,0,0,0.5); }
        .popup-right { color: white; flex: 1; min-width: 280px; }
        .popup-right h2 { font-family: 'Bebas Neue', sans-serif; font-size: 2.4rem; color: #e50914; margin-bottom: 8px; }

        .show-genres { font-family: 'Montserrat', sans-serif; font-size: 14px; color: #ccc; margin-bottom: 8px; font-style: italic; }

        .season-thumb {
            flex: 0 0 160px;
            cursor: pointer;
            position: relative;
            text-align: center;
            transition: transform 0.25s;
        }
        .season-thumb:hover { transform: scale(1.06); }
        .season-thumb img { width: 100%; height: 240px; object-fit: cover; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.5); }

        .episode-card {
            background: #222;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.25s;
        }
        .episode-card:hover { transform: scale(1.04); }
        .episode-card img { width: 100%; height: 100%; object-fit: cover; }

        /* ─── POPUP BADGE ─── */
        .type-badge {
            display: inline-block;
            background: #e50914;
            color: white;
            padding: 3px 12px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        /* ─── RATING ─── */
        .rating { color: #ffd700; margin: 10px 0; font-size: 15px; }

        /* ─── VOIR PLUS ─── */
        #voir-plus-card {
            min-width: 120px;
            height: 278px;
            background: #2a2a2a;
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 48px;
            font-weight: bold;
            cursor: pointer;
            color: #888;
            transition: background 0.3s, color 0.3s;
            flex-shrink: 0;
        }
        #voir-plus-card:hover { background: #e50914; color: white; }

        /* ─── GENRE RANDOM POPUP ─── */
        .genre-btn {
            display: flex;
            align-items: center;
            background: #2a2a2a;
            color: white;
            padding: 16px 22px;
            border: 2px solid #444;
            border-radius: 10px;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.25s;
            text-align: left;
            gap: 10px;
        }
        .genre-btn:hover { border-color: #e50914; background: #333; transform: translateY(-2px); }
        .genre-btn input[type=checkbox] { accent-color: #e50914; width: 18px; height: 18px; cursor: pointer; }

        /* ─── FOOTER ─── */
        footer {
            text-align: center;
            padding: 50px 20px 30px;
            color: #888;
        }
        footer hr { border: none; border-top: 1px solid #333; width: 80%; margin: 0 auto 25px; }
        footer p { font-size: 13px; line-height: 1.7; max-width: 700px; margin: 0 auto; font-style: italic; }

        /* ─── SCROLLBAR ─── */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #333; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #e50914; border-radius: 10px; }

        /* ─── RESPONSIVE ─── */
        @media (max-width: 768px) {
            .header { padding: 15px 20px; }
            .logo { font-size: 36px; }
            .nav-left { gap: 10px; }
            .nav-links {
                display: none;
                flex-direction: column;
                background: rgba(0,0,0,0.95);
                position: absolute;
                top: 70px; left: 0;
                width: 100%;
                padding: 20px;
                gap: 15px;
                align-items: center;
            }
            .nav-links.active { display: flex; }
            .burger { display: flex; }
            .login-btn { display: none; }
            .user-icon-mobile { display: block; }
            #search-input { width: 100%; font-size: 13px; padding: 7px 10px; }
            .search-container { flex: 1; margin: 0 8px; }
            .content { padding: 30px 20px 60px; }
            .hero { height: 70vh; }
            .hero-title { font-size: 28px; }
            .hero-description { font-size: 14px; }
            .hero-poster { width: 150px; }
            .hero-overlay { padding: 0 20px; }
            .tv-popup { padding: 20px; }
            .popup-left img { width: 160px; }
        }
        @media (max-width: 480px) {
            .hero-poster { display: none; }
            .hero-content { max-width: 100%; }
            #randomBtn { padding: 12px 20px; font-size: 15px; right: 15px; bottom: 20px; }
        }
    </style>
</head>
