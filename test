// ─── UTILS ───
function removeAccents(str) {
    return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
}

function dedupe(arr) {
    const seen = new Set();
    return arr.filter(item => {
        const t = item.title || item.name;
        if (!t || seen.has(t)) return false;
        seen.add(t); return true;
    });
}

async function tmdb(path) {
    const sep = path.includes('?') ? '&' : '?';
    const res = await fetch(`https://api.themoviedb.org/3${path}${sep}api_key=${API_KEY}&language=fr-FR`);
    return res.json();
}

// ─── CRÉER UNE CARTE ───
function createCard(item, type) {
    const title = item.title || item.name;
    const year = (item.release_date || item.first_air_date || '').slice(0, 4);
    const poster = item.poster_path ? `${BASE_IMG}w500${item.poster_path}` : '';

    const card = document.createElement('div');
    card.className = 'movie-card';
    if (poster) card.style.backgroundImage = `url('${poster}')`;
    else card.style.background = '#2a2a2a';

    card.innerHTML = `
        <div class="card-overlay">
            <div class="card-title">${title}</div>
            <div class="card-meta">${year}${type === 'tv' ? ' • Série' : ' • Film'}</div>
        </div>`;

    card.addEventListener('click', () => openPopup({ ...item, type }));
    return card;
}

function populateRow(containerId, items, type) {
    const container = document.getElementById(containerId);
    if (!container) return;
    dedupe(items).slice(0, 20).forEach(item => container.appendChild(createCard(item, type)));
}

// ─── HERO CAROUSEL ───
let heroMovies = [], heroIndex = 0, heroTimer = null;

async function loadHero() {
    const data = await tmdb('/movie/now_playing?page=1');
    heroMovies = (data.results || []).filter(m => m.backdrop_path && m.poster_path).slice(0, 12);
    if (heroMovies.length) { updateHero(); startHeroTimer(); }
}

function startHeroTimer() {
    clearInterval(heroTimer);
    heroTimer = setInterval(() => { heroIndex = (heroIndex + 1) % heroMovies.length; updateHero(); }, 6000);
}

function updateHero() {
    const movie = heroMovies[heroIndex];
    const content = document.getElementById('heroContent');
    const poster = document.getElementById('heroPoster');
    const section = document.querySelector('.hero');

    content.classList.add('fade-out');
    setTimeout(() => {
        section.style.backgroundImage = `url('${BASE_IMG}original${movie.backdrop_path}')`;
        document.getElementById('heroTitle').textContent = movie.title;
        document.getElementById('heroDescription').textContent = movie.overview
            ? movie.overview.slice(0, 200) + (movie.overview.length > 200 ? '...' : '')
            : '';
        document.getElementById('heroPlayBtn').href = `${WATCH_BASE}/movie/${movie.id}`;
        document.getElementById('heroInfoBtn').onclick = (e) => { e.preventDefault(); openPopup({ ...movie, type: 'movie' }); };
        poster.src = `${BASE_IMG}w342${movie.poster_path}`;
        poster.onclick = () => openPopup({ ...movie, type: 'movie' });
        content.classList.remove('fade-out');
        content.classList.add('fade-in');
        setTimeout(() => content.classList.remove('fade-in'), 800);
    }, 400);
}

document.getElementById('heroPrev').addEventListener('click', () => {
    heroIndex = (heroIndex - 1 + heroMovies.length) % heroMovies.length;
    updateHero(); startHeroTimer();
});
document.getElementById('heroNext').addEventListener('click', () => {
    heroIndex = (heroIndex + 1) % heroMovies.length;
    updateHero(); startHeroTimer();
});

