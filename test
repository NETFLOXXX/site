function showGenreSelection(contentType) {
    const movieGenres = [{id:28,name:'Action'},{id:12,name:'Aventure'},{id:16,name:'Animation'},{id:35,name:'Comédie'},
        {id:80,name:'Crime'},{id:99,name:'Documentaire'},{id:18,name:'Drame'},{id:14,name:'Fantastique'},
        {id:27,name:'Horreur'},{id:10749,name:'Romance'},{id:878,name:'Science-Fiction'},{id:53,name:'Thriller'},{id:37,name:'Western'}];
    const tvGenres = [{id:10759,name:'Action & Aventure'},{id:16,name:'Animation'},{id:35,name:'Comédie'},
        {id:80,name:'Crime'},{id:99,name:'Documentaire'},{id:18,name:'Drame'},{id:10765,name:'Sci-fi & Fantastique'},{id:37,name:'Western'}];

    const genres = contentType === 'movie' ? movieGenres : tvGenres;

    const overlay = document.createElement('div');
    overlay.className = 'tv-overlay';
    overlay.innerHTML = `
        <div class="tv-popup" style="max-width:640px;">
            <span class="close-btn">&times;</span>
            <h2 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#e50914;margin-bottom:20px;">Choisissez vos genres</h2>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
                ${genres.map(g => `
                    <label class="genre-btn" style="cursor:pointer;">
                        <input type="checkbox" value="${g.id}"> ${g.name}
                    </label>`).join('')}
            </div>
            <div style="display:flex;gap:12px;justify-content:center;">
                <button class="btn btn-secondary" onclick="doRandomNoGenre()">🎲 Peu importe</button>
                <button class="btn btn-primary" onclick="launchGenreRandom('${contentType}')">✨ Lancer !</button>
            </div>
        </div>`;
    attachOverlay(overlay);

    window.doRandomNoGenre = () => { overlay.remove(); currentSearchParams = {contentType, selectedGenres:[]}; doRandom(contentType, []); };
    window.launchGenreRandom = (type) => {
        const selected = [...overlay.querySelectorAll('input:checked')].map(c => c.value);
        overlay.remove();
        currentSearchParams = { contentType: type, selectedGenres: selected };
        doRandom(type, selected);
    };
}

async function doRandom(contentType, selectedGenres) {
    const genreParam = selectedGenres.length ? `&with_genres=${selectedGenres.join(',')}` : '';
    const pool = [];

    const pages = [Math.ceil(Math.random()*10), Math.ceil(Math.random()*10+10), Math.ceil(Math.random()*20+20)];

    const fetches = [];
    if (contentType === 'movie' || contentType === 'both') {
        pages.forEach(p => fetches.push(
            tmdb(`/discover/movie?sort_by=popularity.desc&page=${p}${genreParam}&vote_count.gte=100`)
                .then(d => (d.results||[]).map(m=>({...m,type:'movie'})))
        ));
    }
    if (contentType === 'tv' || contentType === 'both') {
        pages.forEach(p => fetches.push(
            tmdb(`/discover/tv?sort_by=popularity.desc&page=${p}${genreParam}&vote_count.gte=50`)
                .then(d => (d.results||[]).map(s=>({...s,type:'tv'})))
        ));
    }

    const results = await Promise.all(fetches);
    results.forEach(r => pool.push(...r));

    const filtered = pool.filter(i => i.vote_average >= 6 && (i.title || i.name));
    const pick = filtered.length ? filtered[Math.floor(Math.random() * filtered.length)]
                                  : pool[Math.floor(Math.random() * pool.length)];

    if (pick) openPopup(pick);
    else alert("Aucun résultat — réessayez !");
}

// ─── INIT ───
loadHero();
loadAllSections();
</script>

